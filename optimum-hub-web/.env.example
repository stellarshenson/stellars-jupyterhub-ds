# Optimum Hub web - environment

# Data mode: mock (MSW fixtures, default - runs with no hub) | live (real readonly GETs)
VITE_DATA_MODE=mock

# Live mode only: hub origin the dev proxy forwards to (self-signed cert ok).
# Auth rides the hub session cookie - no API token is needed.
VITE_HUB_ORIGIN=https://localhost

# Base path when the build is served behind the hub at a sub-path (default /)
# VITE_BASE=/jupyterhub/portal/
