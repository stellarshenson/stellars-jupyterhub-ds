# Hub-served build (`npm run build:hub` / `make assets`) - the portal the
# JupyterHub renders at /hub/portal, bundled inside the optimum-hub-web wheel.
VITE_DATA_MODE=live
# Vite asset + router base. The running hub uses base_url=/ so the hub prefix is
# /hub and the portal mounts at /hub/portal/. A /jupyterhub-mounted hub would
# need VITE_BASE=/jupyterhub/hub/portal/ (rebuild required).
VITE_BASE=/hub/portal/
# Hub API prefix. base_url=/ -> API at /hub/api (empty prefix).
VITE_HUB_BASE=
