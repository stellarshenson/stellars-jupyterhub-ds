# Live build (`npm run build:live` / `make build-live`) - the target portal that
# connects to the real hub. Served same-origin behind Traefik at /portal.
VITE_DATA_MODE=live
# Vite asset/router base - the portal is mounted at /portal on the hub's host.
VITE_BASE=/portal/
# Hub API prefix. The running hub uses base_url=/ so the API is at /hub/api
# (empty prefix). For a /jupyterhub path-mounted hub, set VITE_HUB_BASE=/jupyterhub.
VITE_HUB_BASE=
